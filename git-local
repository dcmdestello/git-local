#!/usr/bin/env bash
set -euo pipefail

# ── global config ─────────────────────────────────────────────────────────────

GLOBAL_DIR="$HOME/.git-local"
GLOBAL_REGISTRY="$GLOBAL_DIR/registry"
GLOBAL_PID="$GLOBAL_DIR/daemon.pid"
GLOBAL_LOG="$GLOBAL_DIR/daemon.log"
LAUNCH_AGENT_LABEL="com.user.git-local"
LAUNCH_AGENT_PATH="$HOME/Library/LaunchAgents/$LAUNCH_AGENT_LABEL.plist"

# ── colors (disabled when output is not a terminal) ──────────────────────────

if [[ -t 1 ]]; then
    C_RED='\033[31m' C_GREEN='\033[32m' C_YELLOW='\033[33m'
    C_CYAN='\033[36m' C_DIM='\033[2m' C_BOLD='\033[1m' C_RST='\033[0m'
else
    C_RED='' C_GREEN='' C_YELLOW='' C_CYAN='' C_DIM='' C_BOLD='' C_RST=''
fi

die() { printf "${C_RED}git-local: %s${C_RST}\n" "$*" >&2; exit 1; }

init() {
    GIT_DIR=$(git rev-parse --git-dir 2>/dev/null) || die "not in a git repository"
    REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || die "cannot find repo root"
    MARKS_FILE="$GIT_DIR/local-marks"
}

init_for_repo() {
    REPO_ROOT="$1"
    GIT_DIR="$REPO_ROOT/.git"
    [[ -d "$GIT_DIR" ]] || return 1
    MARKS_FILE="$GIT_DIR/local-marks"
}

# Resolve a path (relative to cwd or absolute) to repo-root-relative
repo_relative() {
    local abs
    abs="$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"
    printf '%s' "${abs#"$REPO_ROOT"/}"
}

# ── exclude helpers (for untracked files) ────────────────────────────────────

_EXCL_BEGIN="# git-local begin"
_EXCL_END="# git-local end"

# Read the exclude file, splitting into our entries and everything else
_excl_read() {
    _EXCL_ENTRIES=()
    _EXCL_OTHER=()
    local exclude="$GIT_DIR/info/exclude"
    [[ -f "$exclude" ]] || return 0
    local in_block=false
    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$line" == "$_EXCL_BEGIN" ]]; then in_block=true; continue; fi
        if [[ "$line" == "$_EXCL_END" ]]; then in_block=false; continue; fi
        if $in_block; then _EXCL_ENTRIES+=("$line"); else _EXCL_OTHER+=("$line"); fi
    done < "$exclude"
}

# Rewrite the exclude file from _EXCL_OTHER + _EXCL_ENTRIES
_excl_write() {
    local exclude="$GIT_DIR/info/exclude"
    mkdir -p "$GIT_DIR/info"
    local tmp="$exclude.tmp"
    for line in ${_EXCL_OTHER[@]+"${_EXCL_OTHER[@]}"}; do
        printf '%s\n' "$line"
    done > "$tmp"
    if [[ ${#_EXCL_ENTRIES[@]} -gt 0 ]]; then
        printf '%s\n' "$_EXCL_BEGIN" >> "$tmp"
        for entry in "${_EXCL_ENTRIES[@]}"; do
            printf '%s\n' "$entry"
        done >> "$tmp"
        printf '%s\n' "$_EXCL_END" >> "$tmp"
    fi
    mv "$tmp" "$exclude"
}

exclude_add() {
    local path="$1"
    _excl_read
    # Don't duplicate
    for e in ${_EXCL_ENTRIES[@]+"${_EXCL_ENTRIES[@]}"}; do
        [[ "$e" == "$path" ]] && return 0
    done
    _EXCL_ENTRIES+=("$path")
    _excl_write
}

exclude_remove() {
    local path="$1"
    _excl_read
    local new_entries=()
    for e in ${_EXCL_ENTRIES[@]+"${_EXCL_ENTRIES[@]}"}; do
        [[ "$e" != "$path" ]] && new_entries+=("$e")
    done
    _EXCL_ENTRIES=()
    for e in ${new_entries[@]+"${new_entries[@]}"}; do
        _EXCL_ENTRIES+=("$e")
    done
    _excl_write
}

# ── marks helpers ────────────────────────────────────────────────────────────

# Remove a path's entry from the marks file
drop_entry() {
    local target="$1"
    [[ -f "$MARKS_FILE" ]] || return 0
    local tmp="$MARKS_FILE.tmp"
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        [[ "${line#* }" != "$target" ]] && printf '%s\n' "$line"
    done < "$MARKS_FILE" > "$tmp"
    mv "$tmp" "$MARKS_FILE"
}


# ── registry ─────────────────────────────────────────────────────────────────

registry_add() {
    mkdir -p "$GLOBAL_DIR"
    local repo="$1"
    if [[ -f "$GLOBAL_REGISTRY" ]]; then
        while IFS= read -r line; do
            [[ "$line" == "$repo" ]] && return 0
        done < "$GLOBAL_REGISTRY"
    fi
    printf '%s\n' "$repo" >> "$GLOBAL_REGISTRY"
}

registry_remove() {
    [[ -f "$GLOBAL_REGISTRY" ]] || return 0
    local repo="$1"
    local tmp="$GLOBAL_REGISTRY.tmp"
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" != "$repo" ]] && printf '%s\n' "$line"
    done < "$GLOBAL_REGISTRY" > "$tmp"
    mv "$tmp" "$GLOBAL_REGISTRY"
}

global_daemon_running() {
    [[ -f "$GLOBAL_PID" ]] || return 1
    local pid
    pid=$(cat "$GLOBAL_PID")
    kill -0 "$pid" 2>/dev/null
}

signal_daemon() {
    global_daemon_running || return 0
    kill -HUP "$(cat "$GLOBAL_PID")" 2>/dev/null || true
}

# Called after marks change to keep the daemon in sync
notify_watcher() {
    if [[ -s "$MARKS_FILE" ]]; then
        registry_add "$REPO_ROOT"
    else
        registry_remove "$REPO_ROOT"
    fi
    if global_daemon_running; then
        signal_daemon
    else
        printf "${C_YELLOW}Note: daemon is not running. Run \"git local service install\" to enable auto-sync.${C_RST}\n"
    fi
}

# ── mark ─────────────────────────────────────────────────────────────────────

cmd_mark() {
    init
    if [[ $# -eq 0 ]]; then
        cmd_interactive
        notify_watcher
        return
    fi

    # Collect modified tracked files
    local files=()
    while IFS= read -r -d '' file; do
        files+=("$file")
    done < <(git diff -z --name-only --relative -- "$@")

    # Also collect untracked files matching the arguments
    local untracked=()
    while IFS= read -r -d '' file; do
        untracked+=("$file")
    done < <(git ls-files -z --others --exclude-standard -- "$@")

    if [[ ${#files[@]} -eq 0 && ${#untracked[@]} -eq 0 ]]; then
        printf 'no modified or untracked files found matching arguments\n'
        return 0
    fi

    for file in ${files[@]+"${files[@]}"}; do
        local rel
        rel=$(repo_relative "$file")

        local hash
        hash=$(git hash-object "$REPO_ROOT/$rel")

        drop_entry "$rel"
        printf '%s %s\n' "$hash" "$rel" >> "$MARKS_FILE"
        git update-index --skip-worktree -- "$rel"

        printf "${C_GREEN}marked:${C_RST} %s ${C_DIM}(%s)${C_RST}\n" "$rel" "${hash:0:8}"
    done

    for file in ${untracked[@]+"${untracked[@]}"}; do
        local rel
        rel=$(repo_relative "$file")

        exclude_add "$rel"
        drop_entry "$rel"
        printf '%s %s\n' "untracked" "$rel" >> "$MARKS_FILE"

        printf "${C_GREEN}marked:${C_RST} %s ${C_DIM}(untracked)${C_RST}\n" "$rel"
    done

    notify_watcher
}

cmd_remark() {
    init
    [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]] || { echo "no files marked"; return 0; }

    local new_marks=() remarked=0 unchanged=0

    while IFS=' ' read -r stored_hash path || [[ -n "$stored_hash" ]]; do
        [[ -z "$stored_hash" || -z "$path" ]] && continue

        # Untracked files: keep if still present, clean up if deleted
        if [[ "$stored_hash" == "untracked" ]]; then
            if [[ -f "$REPO_ROOT/$path" ]]; then
                new_marks+=("untracked $path")
                ((unchanged++)) || true
            else
                exclude_remove "$path"
                printf "${C_DIM}removed: %s (deleted)${C_RST}\n" "$path"
            fi
            continue
        fi

        if [[ ! -f "$REPO_ROOT/$path" ]]; then
            git update-index --no-skip-worktree -- "$path" 2>/dev/null || true
            continue
        fi

        local current
        current=$(git hash-object "$REPO_ROOT/$path")

        if [[ "$current" != "$stored_hash" ]]; then
            new_marks+=("$current $path")
            git update-index --skip-worktree -- "$path" 2>/dev/null || true
            printf "${C_CYAN}re-marked:${C_RST} %s\n" "$path"
            ((remarked++)) || true
        else
            new_marks+=("$stored_hash $path")
            ((unchanged++)) || true
        fi
    done < "$MARKS_FILE"

    # Rewrite marks file
    local tmp="$MARKS_FILE.tmp"
    printf '%s\n' ${new_marks[@]+"${new_marks[@]}"} > "$tmp"
    mv "$tmp" "$MARKS_FILE"

    if [[ $remarked -eq 0 ]]; then
        printf 'all %s files already up to date\n' "$unchanged"
    else
        [[ $unchanged -gt 0 ]] && printf "${C_DIM}%s files unchanged${C_RST}\n" "$unchanged"
    fi

    notify_watcher
}

# ── interactive ──────────────────────────────────────────────────────────────

cmd_interactive() {
    # Collect into groups, then merge: changed → modified → untracked → hidden
    # Sentinel entries (empty candidate) act as visual separators.

    local seen=()
    local candidates=()
    local display_names=()
    local selected=()
    local is_marked=()
    local is_changed=()
    local is_untracked=()

    _seen() {
        local target="$1"
        for s in "${seen[@]+"${seen[@]}"}"; do [[ "$s" == "$target" ]] && return 0; done
        return 1
    }

    _add_separator() {
        local len=${#candidates[@]}
        [[ $len -gt 0 && "${candidates[$((len-1))]}" != "" ]] || return 0
        candidates+=("")
        display_names+=("")
        selected+=(false)
        is_marked+=(false)
        is_changed+=(false)
        is_untracked+=(false)
    }

    # Temporary per-group arrays (each entry is "idx" into the parallel arrays)
    local g_changed=() g_modified=() g_untracked=() g_hidden=()

    # ── Collect marked files (split into changed, hidden, or excluded) ──
    if [[ -f "$MARKS_FILE" ]]; then
        while IFS=' ' read -r stored_hash path || [[ -n "$stored_hash" ]]; do
            [[ -z "$stored_hash" || -z "$path" ]] && continue
            _seen "$path" && continue
            seen+=("$path")

            # Untracked files hidden via exclude — show in hidden group
            if [[ "$stored_hash" == "untracked" ]]; then
                if [[ -f "$REPO_ROOT/$path" ]]; then
                    g_hidden+=("$path|true|false|true|$path ${C_GREEN}(excluded)${C_RST}|true")
                else
                    # File deleted, auto-clean
                    drop_entry "$path"
                    exclude_remove "$path"
                fi
                continue
            fi

            # Auto-clean deleted tracked files
            if [[ ! -f "$REPO_ROOT/$path" ]]; then
                drop_entry "$path"
                git update-index --no-skip-worktree -- "$path" 2>/dev/null || true
                continue
            fi

            local current_hash
            current_hash=$(git hash-object "$REPO_ROOT/$path")
            if [[ "$current_hash" == "$stored_hash" ]]; then
                g_hidden+=("$path|true|false|false|$path ${C_GREEN}(hidden)${C_RST}|true")
            else
                g_changed+=("$path|true|true|false|$path ${C_YELLOW}(changed)${C_RST}|false")
            fi
        done < "$MARKS_FILE"
    fi

    # ── Collect modified files ──
    while IFS= read -r -d '' path; do
        _seen "$path" && continue
        seen+=("$path")
        g_modified+=("$path|false|false|false|$path ${C_CYAN}(modified)${C_RST}|false")
    done < <(git -C "$REPO_ROOT" diff -z --name-only)

    # ── Collect untracked files ──
    while IFS= read -r -d '' path; do
        _seen "$path" && continue
        seen+=("$path")
        g_untracked+=("$path|false|false|true|$path ${C_DIM}(untracked)${C_RST}|false")
    done < <(git -C "$REPO_ROOT" ls-files -z --others --exclude-standard)

    # ── Merge groups in order: changed → modified → untracked → hidden ──
    _unpack_group() {
        for entry in "$@"; do
            local IFS='|'
            read -r _p _m _c _u _d _s <<< "$entry"
            candidates+=("$_p")
            is_marked+=("$_m")
            is_changed+=("$_c")
            is_untracked+=("$_u")
            display_names+=("$_d")
            selected+=("$_s")
        done
    }

    local first_group=true
    for group_name in g_changed g_modified g_untracked g_hidden; do
        eval "local group_size=\${#${group_name}[@]}"
        [[ $group_size -eq 0 ]] && continue
        if $first_group; then
            first_group=false
        else
            _add_separator
        fi
        eval '_unpack_group "${'"$group_name"'[@]}"'
    done

    if [[ ${#candidates[@]} -eq 0 ]]; then
        echo "No modified, untracked, or marked files found."
        return 0
    fi

    local current=0
    local total=${#candidates[@]}

    # Skip sentinel if cursor starts on one
    while [[ $current -lt $total && -z "${candidates[$current]}" ]]; do
        ((current++)) || true
    done

    # ── Navigation helpers (skip sentinels) ──
    _move_down() {
        local start=$current
        while true; do
            ((current++)) || true
            [[ $current -ge $total ]] && current=0
            [[ -n "${candidates[$current]}" || $current -eq $start ]] && break
        done
    }
    _move_up() {
        local start=$current
        while true; do
            ((current--)) || true
            [[ $current -lt 0 ]] && current=$((total-1))
            [[ -n "${candidates[$current]}" || $current -eq $start ]] && break
        done
    }

    # ── TUI Loop ──
    printf '\033[?25l'
    trap "printf '\033[?25h'" EXIT

    while true; do
        printf '\033[2J\033[H'

        printf "${C_BOLD}Select files to mark (hide from git):${C_RST}\n"
        printf "  ${C_DIM}[Space] toggle  [Enter] confirm  [q] cancel${C_RST}\n"
        printf "  ${C_DIM}[w/s] or [Up/Down] to move${C_RST}\n"
        echo ""

        for ((i=0; i<total; i++)); do
            # Sentinel: blank separator line
            if [[ -z "${candidates[$i]}" ]]; then
                echo ""
                continue
            fi

            local cursor=" "
            if [[ $i -eq $current ]]; then cursor=">"; fi

            local box
            if ${selected[$i]}; then
                box="${C_GREEN}[x]${C_RST}"
            else
                box="[ ]"
            fi

            if [[ $i -eq $current ]]; then
                printf "%s \033[7m%b %b\033[0m\n" "$cursor" "$box" "${display_names[$i]}"
            else
                printf "%s %b %b\n" "$cursor" "$box" "${display_names[$i]}"
            fi
        done

        local key
        IFS= read -rsn1 key

        case "$key" in
            "") break ;;
            "q") return 0 ;;
            " ")
                if ${selected[$current]}; then
                    selected[$current]=false
                else
                    selected[$current]=true
                fi
                ;;
            "a") # Select all (skip sentinels)
                for ((ii=0; ii<total; ii++)); do
                    [[ -n "${candidates[$ii]}" ]] && selected[$ii]=true
                done
                ;;
            "n") # Deselect all (skip sentinels)
                for ((ii=0; ii<total; ii++)); do
                    [[ -n "${candidates[$ii]}" ]] && selected[$ii]=false
                done
                ;;
            "s"|"j") _move_down ;;
            "w"|"k") _move_up ;;
            $'\x1b')
                read -rsn2 -t 1 key
                case "$key" in
                    "[A") _move_up ;;
                    "[B") _move_down ;;
                esac
                ;;
        esac
    done

    # ── Apply changes ──
    printf '\n'

    for ((i=0; i<total; i++)); do
        local path="${candidates[$i]}"
        [[ -z "$path" ]] && continue  # skip sentinels

        local was_marked="${is_marked[$i]}"
        local is_selected="${selected[$i]}"
        local changed="${is_changed[$i]}"
        local untracked="${is_untracked[$i]}"

        if $is_selected && ! $was_marked; then
            # New mark
            if $untracked; then
                exclude_add "$path"
                drop_entry "$path"
                printf '%s %s\n' "untracked" "$path" >> "$MARKS_FILE"
            else
                local hash
                hash=$(git hash-object "$REPO_ROOT/$path")
                drop_entry "$path"
                printf '%s %s\n' "$hash" "$path" >> "$MARKS_FILE"
                git update-index --skip-worktree -- "$path"
            fi
            printf "${C_GREEN}marked:${C_RST} %s\n" "$path"
        elif $is_selected && $was_marked && $changed; then
            # Re-mark with updated hash (only for tracked files)
            local hash
            hash=$(git hash-object "$REPO_ROOT/$path")
            drop_entry "$path"
            printf '%s %s\n' "$hash" "$path" >> "$MARKS_FILE"
            git update-index --skip-worktree -- "$path" 2>/dev/null || true
            printf "${C_CYAN}re-marked:${C_RST} %s\n" "$path"
        elif ! $is_selected && $was_marked; then
            # Unmark
            drop_entry "$path"
            if $untracked; then
                exclude_remove "$path"
            else
                git update-index --no-skip-worktree -- "$path" 2>/dev/null || true
            fi
            printf "${C_YELLOW}unmarked:${C_RST} %s\n" "$path"
        fi
    done
}

# ── unmark ───────────────────────────────────────────────────────────────────

cmd_unmark() {
    [[ $# -eq 0 ]] && die "usage: git local unmark <pathspec>... (e.g. . or *)"
    init

    [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]] \
        || { echo "no files currently marked"; return 0; }

    local tracked_marks=() untracked_marks=()
    while IFS=' ' read -r hash path || [[ -n "$hash" ]]; do
        [[ -z "$hash" || -z "$path" ]] && continue
        if [[ "$hash" == "untracked" ]]; then
            untracked_marks+=("$path")
        else
            tracked_marks+=("$path")
        fi
    done < "$MARKS_FILE"

    local found_any=false

    # Unmark tracked files via git ls-files pathspec matching
    if [[ ${#tracked_marks[@]} -gt 0 ]]; then
        while IFS= read -r -d '' cand; do
            local rel_cand
            rel_cand=$(repo_relative "$cand")

            for mark in "${tracked_marks[@]}"; do
                if [[ "$rel_cand" == "$mark" ]]; then
                    drop_entry "$mark"
                    git update-index --no-skip-worktree -- "$mark" 2>/dev/null || true
                    printf "${C_YELLOW}unmarked:${C_RST} %s\n" "$mark"
                    found_any=true
                    break
                fi
            done
        done < <(git ls-files -z -- "$@")
    fi

    # Unmark untracked (excluded) files by matching args against paths
    for mark in ${untracked_marks[@]+"${untracked_marks[@]}"}; do
        for arg in "$@"; do
            local rel_arg
            rel_arg=$(repo_relative "$arg")
            # Match: exact path, "." (all), or directory prefix
            if [[ "$mark" == "$rel_arg" || "$rel_arg" == "." || "$mark" == "$rel_arg"/* ]]; then
                drop_entry "$mark"
                exclude_remove "$mark"
                printf "${C_YELLOW}unmarked:${C_RST} %s\n" "$mark"
                found_any=true
                break
            fi
        done
    done

    if ! $found_any; then
         printf 'no marked files matched arguments\n'
    fi

    notify_watcher
}

# ── sync ─────────────────────────────────────────────────────────────────────

# Core sync logic — uses REPO_ROOT/MARKS_FILE set by init or init_for_repo.
# All git commands use -C to work without requiring cwd to be in the repo.
do_sync() {
    [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]] || return 0

    local hashes=() paths=() dirty=false

    while IFS=' ' read -r h p || [[ -n "$h" ]]; do
        [[ -z "$h" ]] && continue
        hashes+=("$h")
        paths+=("$p")
    done < "$MARKS_FILE"

    for i in "${!paths[@]}"; do
        local p="${paths[$i]}"
        local stored="${hashes[$i]}"
        local full="$REPO_ROOT/$p"

        # Untracked files: only need to clean up if deleted
        if [[ "$stored" == "untracked" ]]; then
            if [[ ! -f "$full" ]]; then
                exclude_remove "$p"
                hashes[$i]=""
                paths[$i]=""
                dirty=true
                printf 'removed: %s (deleted untracked)\n' "$p"
            fi
            continue
        fi

        if [[ ! -f "$full" ]]; then
            git -C "$REPO_ROOT" update-index --no-skip-worktree -- "$p" 2>/dev/null || true
            hashes[$i]=""
            paths[$i]=""
            dirty=true
            printf 'removed: %s (file deleted)\n' "$p"
            continue
        fi

        local status_char
        status_char=$(git -C "$REPO_ROOT" ls-files -v -- "$p" | cut -c1)

        local current
        current=$(git hash-object "$full")

        if [[ "$current" == "$stored" ]]; then
            if [[ "$status_char" != "S" ]]; then
                git -C "$REPO_ROOT" update-index --skip-worktree -- "$p" 2>/dev/null || true
                printf 'hidden: %s (content matches)\n' "$p"
            fi
        else
            if [[ "$status_char" == "S" ]]; then
                git -C "$REPO_ROOT" update-index --no-skip-worktree -- "$p" 2>/dev/null || true
                printf 'revealed: %s (content changed)\n' "$p"
            fi
        fi
    done

    if $dirty; then
        local tmp="$MARKS_FILE.tmp"
        for i in "${!paths[@]}"; do
            [[ -n "${paths[$i]}" ]] && printf '%s %s\n' "${hashes[$i]}" "${paths[$i]}"
        done > "$tmp"
        mv "$tmp" "$MARKS_FILE"
    fi
}

cmd_sync() {
    init
    do_sync
}

# ── status ───────────────────────────────────────────────────────────────────

cmd_status() {
    init

    if global_daemon_running; then
        printf "Daemon: ${C_GREEN}RUNNING${C_RST} (PID %s)\n" "$(cat "$GLOBAL_PID")"
    else
        printf "Daemon: ${C_RED}STOPPED${C_RST}\n"
        if [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]]; then
             printf "${C_DIM}(Run \"git local service install\" to enable auto-sync)${C_RST}\n"
        fi
    fi
    echo ""

    [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]] || { echo "no files marked"; return 0; }

    printf "${C_BOLD}%-45s  %-8s  %s${C_RST}\n" "FILE" "STATE" "HASH"
    printf "${C_DIM}%-45s  %-8s  %s${C_RST}\n" "----" "-----" "----"

    while IFS=' ' read -r stored_hash path || [[ -n "$stored_hash" ]]; do
        [[ -z "$stored_hash" ]] && continue
        local full="$REPO_ROOT/$path"
        local state state_color hash_display

        if [[ "$stored_hash" == "untracked" ]]; then
            state="excluded"
            state_color="$C_GREEN"
            hash_display="-"
        elif [[ ! -f "$full" ]]; then
            state="deleted"
            state_color="$C_RED"
            hash_display="${stored_hash:0:8}"
        else
            local current
            current=$(git hash-object "$full")
            if [[ "$current" == "$stored_hash" ]]; then
                state="hidden"
                state_color="$C_GREEN"
            else
                state="changed"
                state_color="$C_YELLOW"
            fi
            hash_display="${stored_hash:0:8}"
        fi

        printf "%-45s  ${state_color}%-8s${C_RST}  ${C_DIM}%s${C_RST}\n" "$path" "$state" "$hash_display"
    done < "$MARKS_FILE"
}

# ── global daemon ────────────────────────────────────────────────────────────

daemon_sync_all() {
    [[ -f "$GLOBAL_REGISTRY" ]] || return 0

    local stale_repos=()
    while IFS= read -r repo || [[ -n "$repo" ]]; do
        [[ -z "$repo" ]] && continue

        if ! init_for_repo "$repo"; then
            stale_repos+=("$repo")
            continue
        fi

        if [[ ! -f "$MARKS_FILE" || ! -s "$MARKS_FILE" ]]; then
            stale_repos+=("$repo")
            continue
        fi

        do_sync
    done < "$GLOBAL_REGISTRY"

    if [[ ${#stale_repos[@]} -gt 0 ]]; then
        for repo in "${stale_repos[@]}"; do
            registry_remove "$repo"
            printf '[%s] Removed stale: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$repo"
        done
    fi
}

# Collect full paths of all marked files across all repos
daemon_collect_watch_paths() {
    DAEMON_WATCH_PATHS=()
    [[ -f "$GLOBAL_REGISTRY" ]] || return 0

    while IFS= read -r repo || [[ -n "$repo" ]]; do
        [[ -z "$repo" || ! -d "$repo/.git" ]] && continue
        local marks="$repo/.git/local-marks"
        [[ -f "$marks" && -s "$marks" ]] || continue
        while IFS=' ' read -r h p || [[ -n "$h" ]]; do
            [[ -n "$p" && "$h" != "untracked" ]] && DAEMON_WATCH_PATHS+=("$repo/$p")
        done < "$marks"
    done < "$GLOBAL_REGISTRY"
}

cmd_daemon() {
    mkdir -p "$GLOBAL_DIR"

    if global_daemon_running; then
        printf 'Daemon already running (PID %s)\n' "$(cat "$GLOBAL_PID")"
        exit 1
    fi

    printf '[%s] Daemon started (PID %s)\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$$"
    echo $$ > "$GLOBAL_PID"

    trap 'rm -f "$GLOBAL_PID"; exit 0' TERM INT
    # SIGHUP interrupts fswatch/sleep, causing an immediate re-sync cycle
    trap 'true' HUP

    if command -v fswatch >/dev/null 2>&1; then
        printf '[%s] Using fswatch\n' "$(date '+%Y-%m-%d %H:%M:%S')"
        while true; do
            daemon_sync_all
            daemon_collect_watch_paths

            if [[ ${#DAEMON_WATCH_PATHS[@]} -gt 0 ]]; then
                # Block until a watched file changes, or SIGHUP interrupts
                fswatch -1 -l 1 "${DAEMON_WATCH_PATHS[@]}" >/dev/null 2>&1 || true
            else
                sleep 30 || true
            fi
        done
    else
        printf '[%s] Using polling (every 5s)\n' "$(date '+%Y-%m-%d %H:%M:%S')"
        while true; do
            daemon_sync_all
            sleep 5 || true
        done
    fi
}

cmd_install_service() {
    local script_path
    script_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

    mkdir -p "$GLOBAL_DIR"
    mkdir -p "$(dirname "$LAUNCH_AGENT_PATH")"

    if [[ -f "$LAUNCH_AGENT_PATH" ]]; then
        printf 'LaunchAgent already exists at %s\n' "$LAUNCH_AGENT_PATH"
        printf 'Run "git local service uninstall" first to reinstall.\n'
        return 1
    fi

    cat > "$LAUNCH_AGENT_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LAUNCH_AGENT_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${script_path}</string>
        <string>daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${GLOBAL_LOG}</string>
    <key>StandardErrorPath</key>
    <string>${GLOBAL_LOG}</string>
</dict>
</plist>
PLIST

    launchctl load -w "$LAUNCH_AGENT_PATH"

    printf "${C_GREEN}Installed global daemon service.${C_RST}\n"
    printf 'LaunchAgent: %s\n' "$LAUNCH_AGENT_PATH"
    printf 'Logs: %s\n' "$GLOBAL_LOG"
    printf '\nRun "git local service" to verify.\n'
}

cmd_uninstall_service() {
    if [[ ! -f "$LAUNCH_AGENT_PATH" ]]; then
        printf 'No LaunchAgent found at %s\n' "$LAUNCH_AGENT_PATH"
        return 1
    fi

    launchctl unload -w "$LAUNCH_AGENT_PATH" 2>/dev/null || true
    rm -f "$LAUNCH_AGENT_PATH"
    rm -f "$GLOBAL_PID"

    printf "${C_YELLOW}Uninstalled global daemon service.${C_RST}\n"
}

cmd_service_status() {
    if global_daemon_running; then
        printf "Daemon: ${C_GREEN}RUNNING${C_RST} (PID %s)\n" "$(cat "$GLOBAL_PID")"
    else
        printf "Daemon: ${C_RED}STOPPED${C_RST}\n"
    fi

    if [[ -f "$LAUNCH_AGENT_PATH" ]]; then
        printf "LaunchAgent: ${C_GREEN}installed${C_RST}\n"
    else
        printf "LaunchAgent: ${C_YELLOW}not installed${C_RST} (run \"git local service install\")\n"
    fi

    if command -v fswatch >/dev/null 2>&1; then
        printf "Watch mode: ${C_GREEN}fswatch${C_RST} (event-driven)\n"
    else
        printf "Watch mode: ${C_YELLOW}polling${C_RST} (every 5s)\n"
        printf "  Install fswatch for instant detection: ${C_BOLD}brew install fswatch${C_RST}\n"
    fi
    printf 'Logs: %s\n' "$GLOBAL_LOG"

    if [[ -f "$GLOBAL_REGISTRY" && -s "$GLOBAL_REGISTRY" ]]; then
        local count
        count=$(wc -l < "$GLOBAL_REGISTRY" | tr -d ' ')
        printf '\nRegistered repos (%s):\n' "$count"
        while IFS= read -r repo; do
            [[ -z "$repo" ]] && continue
            local marks_count=0
            local marks_file="$repo/.git/local-marks"
            if [[ -f "$marks_file" && -s "$marks_file" ]]; then
                marks_count=$(wc -l < "$marks_file" | tr -d ' ')
            fi
            printf '  %s (%s files)\n' "$repo" "$marks_count"
        done < "$GLOBAL_REGISTRY"
    else
        printf '\nNo repos registered.\n'
    fi
}

# ── main ─────────────────────────────────────────────────────────────────────

case "${1:-mark}" in
    mark)   [[ $# -gt 0 ]] && shift; cmd_mark "$@" ;;
    remark) cmd_remark ;;
    unmark) shift; cmd_unmark "$@" ;;
    sync)   cmd_sync ;;
    status|ls) cmd_status ;;
    daemon) shift; cmd_daemon "$@" ;;
    service)
        shift
        case "${1:-status}" in
            install)   cmd_install_service ;;
            uninstall) cmd_uninstall_service ;;
            status)    cmd_service_status ;;
            *)         die "unknown service command: $1 (try install, uninstall, status)" ;;
        esac
        ;;
    help|-h|--help)
        cat <<USAGE
usage: git local <command> [args]

commands:
  mark              Interactive mode: select files to hide/show
  mark <spec>...    Mark matching modified files immediately
  remark            Re-mark all changed files (useful after pull/merge)
  unmark <spec>...  Unmark matching files
  sync              Re-check marked files; reveal any with real changes
  status            List marked files and their current state

daemon:
  service           Show daemon status (alias: service status)
  service install   Install daemon as a LaunchAgent (survives reboots)
  service uninstall Remove daemon

Tracked files are hidden via --skip-worktree. When the content hash
diverges from the snapshot taken at mark time, the daemon reveals
the file to git. Untracked files are hidden via .git/info/exclude.

After committing real changes, re-run 'mark' to re-hide local edits.

A single background daemon watches all repos. Install it once with
'git local service install' and it manages everything automatically.
USAGE
        ;;
    *)  die "unknown command: $1 (see 'git local help')" ;;
esac
