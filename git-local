#!/usr/bin/env bash
set -euo pipefail

# ── global config ─────────────────────────────────────────────────────────────

GLOBAL_DIR="$HOME/.git-local"
GLOBAL_REGISTRY="$GLOBAL_DIR/registry"
GLOBAL_PID="$GLOBAL_DIR/daemon.pid"
GLOBAL_LOG="$GLOBAL_DIR/daemon.log"
LAUNCH_AGENT_LABEL="com.user.git-local"
LAUNCH_AGENT_PATH="$HOME/Library/LaunchAgents/$LAUNCH_AGENT_LABEL.plist"

die() { printf 'git-local: %s\n' "$*" >&2; exit 1; }

init() {
    GIT_DIR=$(git rev-parse --git-dir 2>/dev/null) || die "not in a git repository"
    REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || die "cannot find repo root"
    MARKS_FILE="$GIT_DIR/local-marks"
    PID_FILE="$GIT_DIR/git-local.pid"
    LOG_FILE="$GIT_DIR/git-local.log"
}

init_for_repo() {
    REPO_ROOT="$1"
    GIT_DIR="$REPO_ROOT/.git"
    [[ -d "$GIT_DIR" ]] || return 1
    MARKS_FILE="$GIT_DIR/local-marks"
    PID_FILE="$GIT_DIR/git-local.pid"
    LOG_FILE="$GIT_DIR/git-local.log"
}

# Resolve a path (relative to cwd or absolute) to repo-root-relative
repo_relative() {
    local abs
    abs="$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"
    printf '%s' "${abs#"$REPO_ROOT"/}"
}

# Remove a path's entry from the marks file
drop_entry() {
    local target="$1"
    [[ -f "$MARKS_FILE" ]] || return 0
    local tmp="$MARKS_FILE.tmp"
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        [[ "${line#* }" != "$target" ]] && printf '%s\n' "$line"
    done < "$MARKS_FILE" > "$tmp"
    mv "$tmp" "$MARKS_FILE"
}

# Print the stored hash for a path (empty string if not found)
stored_hash_for() {
    local target="$1"
    [[ -f "$MARKS_FILE" ]] || return 0
    while IFS=' ' read -r hash path || [[ -n "$hash" ]]; do
        [[ -z "$hash" ]] && continue
        if [[ "$path" == "$target" ]]; then
            printf '%s' "$hash"
            return 0
        fi
    done < "$MARKS_FILE"
}

# Check if per-repo watcher daemon is running
is_running() {
    [[ -f "$PID_FILE" ]] || return 1
    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
        return 0
    else
        rm "$PID_FILE" # Stale PID file
        return 1
    fi
}

# ── registry ─────────────────────────────────────────────────────────────────

registry_add() {
    mkdir -p "$GLOBAL_DIR"
    local repo="$1"
    if [[ -f "$GLOBAL_REGISTRY" ]]; then
        while IFS= read -r line; do
            [[ "$line" == "$repo" ]] && return 0
        done < "$GLOBAL_REGISTRY"
    fi
    printf '%s\n' "$repo" >> "$GLOBAL_REGISTRY"
}

registry_remove() {
    [[ -f "$GLOBAL_REGISTRY" ]] || return 0
    local repo="$1"
    local tmp="$GLOBAL_REGISTRY.tmp"
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" != "$repo" ]] && printf '%s\n' "$line"
    done < "$GLOBAL_REGISTRY" > "$tmp"
    mv "$tmp" "$GLOBAL_REGISTRY"
}

global_daemon_running() {
    [[ -f "$GLOBAL_PID" ]] || return 1
    local pid
    pid=$(cat "$GLOBAL_PID")
    kill -0 "$pid" 2>/dev/null
}

signal_daemon() {
    global_daemon_running || return 0
    kill -HUP "$(cat "$GLOBAL_PID")" 2>/dev/null || true
}

# ── per-repo daemon management ───────────────────────────────────────────────

cmd_watch() {
    init
    if is_running; then
        printf 'Watcher already running (PID %s)\n' "$(cat "$PID_FILE")"
        return 0
    fi

    if ! command -v fswatch >/dev/null 2>&1; then
        printf '\033[33mWarning: fswatch not found.\033[0m\n'
        printf 'Watcher will run in polling mode (every 3s).\n'
        printf 'Install fswatch for instant updates: \033[1mbrew install fswatch\033[0m\n\n'
    fi

    nohup "$0" loop > "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    disown $! 2>/dev/null || true

    printf 'Started background watcher (PID %s)\n' "$(cat "$PID_FILE")"
    printf 'Logs at: %s\n' "$LOG_FILE"
    printf 'Run "git local stop" to stop it.\n'
}

cmd_stop() {
    init
    if is_running; then
        local pid
        pid=$(cat "$PID_FILE")
        kill "$pid" 2>/dev/null || true
        rm "$PID_FILE"
        printf 'Stopped watcher (PID %s)\n' "$pid"
    else
        printf 'Watcher is not running.\n'
    fi
}

cmd_restart() {
    cmd_stop
    cmd_watch
}

# Called after marks change to keep the right watcher strategy in sync
notify_watcher() {
    if [[ -s "$MARKS_FILE" ]]; then
        registry_add "$REPO_ROOT"
        if global_daemon_running; then
            signal_daemon
        elif is_running; then
            cmd_restart >/dev/null 2>&1
        else
            cmd_watch
        fi
    else
        registry_remove "$REPO_ROOT"
        if global_daemon_running; then
            signal_daemon
        elif is_running; then
            cmd_stop
        fi
    fi
}

# ── mark ─────────────────────────────────────────────────────────────────────

cmd_mark() {
    init
    if [[ $# -eq 0 ]]; then
        cmd_interactive
        notify_watcher
        return
    fi

    # Capture files into an array using -z for safety with spaces/special chars
    local files=()
    while IFS= read -r -d '' file; do
        files+=("$file")
    done < <(git diff -z --name-only --relative -- "$@")

    if [[ ${#files[@]} -eq 0 ]]; then
        printf 'no modified files found matching arguments\n'
        return 0
    fi

    for file in "${files[@]}"; do
        # git diff output is relative to CWD (due to --relative), which repo_relative handles
        local rel
        rel=$(repo_relative "$file")

        # Double check it's tracked (git diff usually implies it, but good to be safe)
        git ls-files --error-unmatch -- "$rel" >/dev/null 2>&1 \
            || { printf 'skipping untracked: %s\n' "$rel"; continue; }

        local hash
        hash=$(git hash-object "$REPO_ROOT/$rel")

        drop_entry "$rel"
        printf '%s %s\n' "$hash" "$rel" >> "$MARKS_FILE"
        git update-index --skip-worktree -- "$rel"

        printf 'marked: %s (%s)\n' "$rel" "${hash:0:8}"
    done

    notify_watcher
}

# ── interactive ──────────────────────────────────────────────────────────────

cmd_interactive() {
    # Gather candidates:
    # 1. Currently marked files
    # 2. Modified files (unstaged changes)
    
    local candidates=()
    local display_names=()
    local selected=()
    local is_marked=()

    # Read marked files
    if [[ -f "$MARKS_FILE" ]]; then
        while IFS=' ' read -r _ path || [[ -n "$path" ]]; do
            [[ -z "$path" ]] && continue
            # Avoid duplicates if file is both marked AND modified (can happen if revealed)
            local exists=false
            if [[ ${#candidates[@]} -gt 0 ]]; then
                for c in "${candidates[@]}"; do [[ "$c" == "$path" ]] && exists=true; done
            fi
            if ! $exists; then
                candidates+=("$path")
                display_names+=("$path (marked)")
                selected+=(true)
                is_marked+=(true)
            fi
        done < "$MARKS_FILE"
    fi

    # Read modified files
    while IFS= read -r -d '' path; do
        local exists=false
        if [[ ${#candidates[@]} -gt 0 ]]; then
            for c in "${candidates[@]}"; do [[ "$c" == "$path" ]] && exists=true; done
        fi
        if ! $exists; then
            candidates+=("$path")
            display_names+=("$path (modified)")
            selected+=(false)
            is_marked+=(false)
        fi
    done < <(git diff -z --name-only "$REPO_ROOT")

    if [[ ${#candidates[@]} -eq 0 ]]; then
        echo "No modified or marked files found."
        return 0
    fi

    local current=0
    local total=${#candidates[@]}

    # TUI Loop
    # Hide cursor
    printf '\033[?25l'
    trap "printf '\033[?25h'" EXIT

    while true; do
        printf '\033[2J\033[H' # Clear screen and home
        
        echo "Select files to MARK (hide changes):"
        echo "  [Space] toggle, [Enter] confirm, [q] cancel"
        echo "  [w/s] or [Up/Down] to move"
        echo ""

        for ((i=0; i<total; i++)); do
            local cursor=" "
            if [[ $i -eq $current ]]; then cursor=">"; fi
            
            local box="[ ]"
            if ${selected[$i]}; then box="[x]"; fi
            
            # Highlight current line
            if [[ $i -eq $current ]]; then
                printf "%s \033[7m%s %s\033[0m\n" "$cursor" "$box" "${display_names[$i]}"
            else
                printf "%s %s %s\n" "$cursor" "$box" "${display_names[$i]}"
            fi
        done

        # Read input (1 char)
        local key
        IFS= read -rsn1 key

        case "$key" in
            "") # Enter
                break
                ;;
            "q")
                return 0
                ;;
            " ") # Space
                if ${selected[$current]}; then
                    selected[$current]=false
                else
                    selected[$current]=true
                fi
                ;;
            "s") # Down
                ((current++)) || true
                [[ $current -ge $total ]] && current=0
                ;;
            "w") # Up
                ((current--)) || true
                [[ $current -lt 0 ]] && current=$((total-1))
                ;;
            $'\x1b') # Escape sequence
                read -rsn2 -t 1 key # read next 2 chars (1s timeout for macOS bash 3.2)
                case "$key" in
                    "[A") # Up
                        ((current--)) || true
                        [[ $current -lt 0 ]] && current=$((total-1))
                        ;;
                    "[B") # Down
                        ((current++)) || true
                        [[ $current -ge $total ]] && current=0
                        ;;
                esac
                ;;
        esac
    done

    # Apply changes
    printf '\nApplying changes...\n'
    
    for ((i=0; i<total; i++)); do
        local path="${candidates[$i]}"
        local was_marked="${is_marked[$i]}"
        local is_selected="${selected[$i]}"

        if $is_selected && ! $was_marked; then
            # Mark it
            local hash
            hash=$(git hash-object "$REPO_ROOT/$path")
            drop_entry "$path"
            printf '%s %s\n' "$hash" "$path" >> "$MARKS_FILE"
            git update-index --skip-worktree -- "$path"
            printf 'marked: %s\n' "$path"
        elif ! $is_selected && $was_marked; then
            # Unmark it
            drop_entry "$path"
            git update-index --no-skip-worktree -- "$path" 2>/dev/null || true
            printf 'unmarked: %s\n' "$path"
        fi
    done
}

# ── unmark ───────────────────────────────────────────────────────────────────

cmd_unmark() {
    [[ $# -eq 0 ]] && die "usage: git local unmark <pathspec>... (e.g. . or *)"
    init

    local marks=()
    while IFS=' ' read -r _ path || [[ -n "$path" ]]; do
        [[ -n "$path" ]] && marks+=("$path")
    done < "$MARKS_FILE"

    [[ ${#marks[@]} -eq 0 ]] && { echo "no files currently marked"; return 0; }

    local found_any=false
    
    while IFS= read -r -d '' cand; do
        local rel_cand
        rel_cand=$(repo_relative "$cand")

        for mark in "${marks[@]}"; do
            if [[ "$rel_cand" == "$mark" ]]; then
                drop_entry "$mark"
                git update-index --no-skip-worktree -- "$mark" 2>/dev/null || true
                printf 'unmarked: %s\n' "$mark"
                found_any=true
                break
            fi
        done
    done < <(git ls-files -z -- "$@")

    if ! $found_any; then
         printf 'no marked files matched arguments\n'
    fi

    notify_watcher
}

# ── sync ─────────────────────────────────────────────────────────────────────

# Core sync logic — uses REPO_ROOT/MARKS_FILE set by init or init_for_repo.
# All git commands use -C to work without requiring cwd to be in the repo.
do_sync() {
    [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]] || return 0

    local hashes=() paths=() dirty=false

    while IFS=' ' read -r h p || [[ -n "$h" ]]; do
        [[ -z "$h" ]] && continue
        hashes+=("$h")
        paths+=("$p")
    done < "$MARKS_FILE"

    for i in "${!paths[@]}"; do
        local p="${paths[$i]}"
        local stored="${hashes[$i]}"
        local full="$REPO_ROOT/$p"

        if [[ ! -f "$full" ]]; then
            git -C "$REPO_ROOT" update-index --no-skip-worktree -- "$p" 2>/dev/null || true
            hashes[$i]=""
            paths[$i]=""
            dirty=true
            printf 'removed: %s (file deleted)\n' "$p"
            continue
        fi

        local status_char
        status_char=$(git -C "$REPO_ROOT" ls-files -v -- "$p" | cut -c1)

        local current
        current=$(git hash-object "$full")

        if [[ "$current" == "$stored" ]]; then
            if [[ "$status_char" != "S" ]]; then
                git -C "$REPO_ROOT" update-index --skip-worktree -- "$p" 2>/dev/null || true
                printf 'hidden: %s (content matches)\n' "$p"
            fi
        else
            if [[ "$status_char" == "S" ]]; then
                git -C "$REPO_ROOT" update-index --no-skip-worktree -- "$p" 2>/dev/null || true
                printf 'revealed: %s (content changed)\n' "$p"
            fi
        fi
    done

    if $dirty; then
        local tmp="$MARKS_FILE.tmp"
        : > "$tmp"
        for i in "${!paths[@]}"; do
            [[ -n "${paths[$i]}" ]] && printf '%s %s\n' "${hashes[$i]}" "${paths[$i]}"
        done > "$tmp"
        mv "$tmp" "$MARKS_FILE"
    fi
}

cmd_sync() {
    init
    do_sync
}

# ── status ───────────────────────────────────────────────────────────────────

cmd_status() {
    init

    if global_daemon_running; then
        printf 'Watcher: \033[32mRUNNING\033[0m (managed by global daemon, PID %s)\n' "$(cat "$GLOBAL_PID")"
    elif is_running; then
        printf 'Watcher: \033[32mRUNNING\033[0m (PID %s)\n' "$(cat "$PID_FILE")"
    else
        printf 'Watcher: \033[31mSTOPPED\033[0m\n'
        if [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]]; then
             printf '(Run "git local watch" or "git local service install" to enable auto-sync)\n'
        fi
    fi
    echo ""

    [[ -f "$MARKS_FILE" && -s "$MARKS_FILE" ]] || { echo "no files marked"; return 0; }

    printf '%-45s  %-8s  %s\n' "FILE" "STATE" "HASH"
    printf '%-45s  %-8s  %s\n' "----" "-----" "----"

    while IFS=' ' read -r stored_hash path || [[ -n "$stored_hash" ]]; do
        [[ -z "$stored_hash" ]] && continue
        local full="$REPO_ROOT/$path"
        local state

        if [[ ! -f "$full" ]]; then
            state="deleted"
        else
            local current
            current=$(git hash-object "$full")
            if [[ "$current" == "$stored_hash" ]]; then
                state="hidden"
            else
                state="changed"
            fi
        fi

        printf '%-45s  %-8s  %s\n' "$path" "$state" "${stored_hash:0:8}"
    done < "$MARKS_FILE"
}

# ── per-repo loop ────────────────────────────────────────────────────────────

cmd_loop() {
    init
    
    if command -v fswatch >/dev/null 2>&1; then
        printf 'Watching for changes with fswatch...\n'
        
        local watch_paths=()
        if [[ -f "$MARKS_FILE" ]]; then
            while IFS=' ' read -r _ path || [[ -n "$path" ]]; do
                [[ -n "$path" ]] && watch_paths+=("$REPO_ROOT/$path")
            done < "$MARKS_FILE"
        fi
        
        if [[ ${#watch_paths[@]} -eq 0 ]]; then
            printf 'No files to watch.\n'
            sleep 3600
        else
            fswatch -o -l 1 "${watch_paths[@]}" | while read -r _; do
                cmd_sync
            done
        fi
    else
        printf 'fswatch not found. Falling back to polling every 3s.\n'
        printf '(Install fswatch for better performance: brew install fswatch)\n'
        
        local interval=3
        while true; do
            sleep "$interval"
            cmd_sync
        done
    fi
}

# ── global daemon ────────────────────────────────────────────────────────────

daemon_sync_all() {
    [[ -f "$GLOBAL_REGISTRY" ]] || return 0

    local stale_repos=()
    while IFS= read -r repo || [[ -n "$repo" ]]; do
        [[ -z "$repo" ]] && continue

        if ! init_for_repo "$repo"; then
            stale_repos+=("$repo")
            continue
        fi

        if [[ ! -f "$MARKS_FILE" || ! -s "$MARKS_FILE" ]]; then
            stale_repos+=("$repo")
            continue
        fi

        do_sync
    done < "$GLOBAL_REGISTRY"

    if [[ ${#stale_repos[@]} -gt 0 ]]; then
        for repo in "${stale_repos[@]}"; do
            registry_remove "$repo"
            printf '[%s] Removed stale: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$repo"
        done
    fi
}

# Collect full paths of all marked files across all repos
daemon_collect_watch_paths() {
    DAEMON_WATCH_PATHS=()
    [[ -f "$GLOBAL_REGISTRY" ]] || return 0

    while IFS= read -r repo || [[ -n "$repo" ]]; do
        [[ -z "$repo" || ! -d "$repo/.git" ]] && continue
        local marks="$repo/.git/local-marks"
        [[ -f "$marks" && -s "$marks" ]] || continue
        while IFS=' ' read -r _ p || [[ -n "$p" ]]; do
            [[ -n "$p" ]] && DAEMON_WATCH_PATHS+=("$repo/$p")
        done < "$marks"
    done < "$GLOBAL_REGISTRY"
}

cmd_daemon() {
    mkdir -p "$GLOBAL_DIR"

    if global_daemon_running; then
        printf 'Daemon already running (PID %s)\n' "$(cat "$GLOBAL_PID")"
        exit 1
    fi

    printf '[%s] Daemon started (PID %s)\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$$"
    echo $$ > "$GLOBAL_PID"

    trap 'rm -f "$GLOBAL_PID"; exit 0' TERM INT
    # SIGHUP interrupts fswatch/sleep, causing an immediate re-sync cycle
    trap 'true' HUP

    if command -v fswatch >/dev/null 2>&1; then
        printf '[%s] Using fswatch\n' "$(date '+%Y-%m-%d %H:%M:%S')"
        while true; do
            daemon_sync_all
            daemon_collect_watch_paths

            if [[ ${#DAEMON_WATCH_PATHS[@]} -gt 0 ]]; then
                # Block until a watched file changes, or SIGHUP interrupts
                fswatch -1 -l 1 "${DAEMON_WATCH_PATHS[@]}" >/dev/null 2>&1 || true
            else
                sleep 30 || true
            fi
        done
    else
        printf '[%s] Using polling (every 5s)\n' "$(date '+%Y-%m-%d %H:%M:%S')"
        while true; do
            daemon_sync_all
            sleep 5 || true
        done
    fi
}

cmd_install_service() {
    local script_path
    script_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

    mkdir -p "$GLOBAL_DIR"
    mkdir -p "$(dirname "$LAUNCH_AGENT_PATH")"

    if [[ -f "$LAUNCH_AGENT_PATH" ]]; then
        printf 'LaunchAgent already exists at %s\n' "$LAUNCH_AGENT_PATH"
        printf 'Run "git local service uninstall" first to reinstall.\n'
        return 1
    fi

    cat > "$LAUNCH_AGENT_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LAUNCH_AGENT_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${script_path}</string>
        <string>daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${GLOBAL_LOG}</string>
    <key>StandardErrorPath</key>
    <string>${GLOBAL_LOG}</string>
</dict>
</plist>
PLIST

    launchctl load -w "$LAUNCH_AGENT_PATH"

    printf 'Installed global daemon service.\n'
    printf 'LaunchAgent: %s\n' "$LAUNCH_AGENT_PATH"
    printf 'Logs: %s\n' "$GLOBAL_LOG"
    printf '\nRun "git local service" to verify.\n'
}

cmd_uninstall_service() {
    if [[ ! -f "$LAUNCH_AGENT_PATH" ]]; then
        printf 'No LaunchAgent found at %s\n' "$LAUNCH_AGENT_PATH"
        return 1
    fi

    launchctl unload -w "$LAUNCH_AGENT_PATH" 2>/dev/null || true
    rm -f "$LAUNCH_AGENT_PATH"
    rm -f "$GLOBAL_PID"

    printf 'Uninstalled global daemon service.\n'
}

cmd_service_status() {
    if global_daemon_running; then
        printf 'Global Daemon: \033[32mRUNNING\033[0m (PID %s)\n' "$(cat "$GLOBAL_PID")"
    else
        printf 'Global Daemon: \033[31mSTOPPED\033[0m\n'
    fi

    if [[ -f "$LAUNCH_AGENT_PATH" ]]; then
        printf 'LaunchAgent: installed\n'
    else
        printf 'LaunchAgent: not installed (run "git local service install")\n'
    fi

    if command -v fswatch >/dev/null 2>&1; then
        printf 'Watch mode: fswatch (event-driven)\n'
    else
        printf 'Watch mode: polling (every 5s)\n'
        printf '  Install fswatch for instant detection: \033[1mbrew install fswatch\033[0m\n'
    fi
    printf 'Logs: %s\n' "$GLOBAL_LOG"

    if [[ -f "$GLOBAL_REGISTRY" && -s "$GLOBAL_REGISTRY" ]]; then
        local count
        count=$(wc -l < "$GLOBAL_REGISTRY" | tr -d ' ')
        printf '\nRegistered repos (%s):\n' "$count"
        while IFS= read -r repo; do
            [[ -z "$repo" ]] && continue
            local marks_count=0
            local marks_file="$repo/.git/local-marks"
            if [[ -f "$marks_file" && -s "$marks_file" ]]; then
                marks_count=$(wc -l < "$marks_file" | tr -d ' ')
            fi
            printf '  %s (%s files)\n' "$repo" "$marks_count"
        done < "$GLOBAL_REGISTRY"
    else
        printf '\nNo repos registered.\n'
    fi
}

# ── main ─────────────────────────────────────────────────────────────────────

case "${1:-help}" in
    mark)   shift; cmd_mark "$@" ;;
    unmark) shift; cmd_unmark "$@" ;;
    sync)   cmd_sync ;;
    status|ls) cmd_status ;;
    watch)  shift; cmd_watch "$@" ;;
    stop)   shift; cmd_stop "$@" ;;
    restart) shift; cmd_restart "$@" ;;
    loop)   shift; cmd_loop "$@" ;;
    daemon) shift; cmd_daemon "$@" ;;
    service)
        shift
        case "${1:-status}" in
            install)   cmd_install_service ;;
            uninstall) cmd_uninstall_service ;;
            status)    cmd_service_status ;;
            *)         die "unknown service command: $1 (try install, uninstall, status)" ;;
        esac
        ;;
    help|-h|--help)
        cat <<'USAGE'
usage: git local <command> [args]

commands:
  mark              Interactive mode: select files to hide/show
  mark <spec>...    Mark matching modified files immediately
  unmark <spec>...  Unmark matching files
  sync              Re-check marked files; reveal any with real changes
  status            List marked files and their current state
  watch             Start per-repo background watcher (auto-starts on mark)
  stop              Stop per-repo background watcher
  restart           Restart per-repo background watcher

global daemon:
  service           Show global daemon status (alias: service status)
  service install   Install global daemon (survives reboots)
  service uninstall Remove global daemon

Files are hidden via --skip-worktree as long as their content hash
matches the snapshot taken at mark time. When the content diverges,
the watcher detects the mismatch and reveals the file to git.

After committing real changes, re-run 'mark' to re-hide local edits.

The watcher auto-starts when you mark files and auto-stops
when all files are unmarked. If the global daemon is installed,
it manages all repos automatically (including after reboots).
USAGE
        ;;
    *)  die "unknown command: $1 (see 'git local help')" ;;
esac
